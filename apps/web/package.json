{
  "name": "web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3210",
    "convex:dev": "convex dev",
    "convex:env:list": "convex env list >> .env.convex",
    "convex:env:set": "convex env set --force < .env.convex",
    "build": "vite build && tsc --noEmit",
    "start": "node .output/server/index.mjs",
    "deploy": "bun run build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "preview": "vite preview",
    "test": "vitest run",
    "format": "biome format",
    "lint": "biome lint",
    "check": "biome check",
    "stats": "cloc . --exclude-dir=node_modules,dist,.output,.tanstack,.content-collections,project.inlang,data,paraglide,vendor,.turbo,.next --vcs git",
    "intent:list": "bun x @tanstack/intent@latest list",
    "intent:install": "bun x @tanstack/intent@latest install",
    "intent:scaffold": "bun x @tanstack/intent@latest scaffold",
    "intent:validate": "bun x @tanstack/intent@latest validate",
    "intent:stale": "bun x @tanstack/intent@latest stale"
  },
  "dependencies": {
    "@convex-dev/better-auth": "^0.11.4",
    "@convex-dev/react-query": "0.1.0",
    "@faker-js/faker": "^10.3.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@t3-oss/env-core": "^0.13.10",
    "@tabler/icons-react": "^3.41.1",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/ai": "latest",
    "@tanstack/ai-anthropic": "latest",
    "@tanstack/ai-client": "latest",
    "@tanstack/ai-gemini": "latest",
    "@tanstack/ai-ollama": "latest",
    "@tanstack/ai-openai": "latest",
    "@tanstack/ai-react": "latest",
    "@tanstack/match-sorter-utils": "latest",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-form": "latest",
    "@tanstack/react-query": "latest",
    "@tanstack/react-query-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/react-store": "latest",
    "@tanstack/react-table": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "@tanstack/store": "latest",
    "@unpic/react": "^1.0.2",
    "better-auth": "1.5.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.34.1",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.577.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "streamdown": "^2.3.0",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.3.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@cloudflare/vite-plugin": "^1.31.0",
    "@inlang/paraglide-js": "^2.13.1",
    "@rolldown/plugin-babel": "^0.2.2",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-event-client": "latest",
    "@tanstack/devtools-vite": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@typescript/native-preview": "^7.0.0-dev.20260405.1",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "jsdom": "^28.1.0",
    "typescript": "6",
    "vite": "^8.0.4",
    "vite-tsconfig-paths": "6",
    "vitest": "^3.0.5",
    "wrangler": "^4.80.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}